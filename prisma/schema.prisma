generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Post {
  id             Int              @id @default(autoincrement())
  title          String
  slug           String           @unique
  content        String
  excerpt        String?
  eyecatch       String?
  published      Boolean          @default(false)
  isPickup       Boolean          @default(false)
  showDate       Boolean          @default(true)
  scheduledAt    DateTime?
  views          Int              @default(0)
  writerId       Int?
  writer         Writer?          @relation(fields: [writerId], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  clicks         Click[]
  pageViews      PageView[]
  categories     PostCategory[]

  @@index([published, createdAt])
  @@index([published, isPickup, createdAt])
  @@index([published, scheduledAt])
  @@index([views])
  @@map("posts")
}

model Category {
  id         Int            @id @default(autoincrement())
  name       String         @unique
  slug       String         @unique
  order      Int            @default(0)
  showInMenu Boolean        @default(false)
  posts      PostCategory[]

  @@map("categories")
}

model PostCategory {
  postId     Int
  categoryId Int
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
  @@index([categoryId])
  @@map("post_categories")
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String

  @@map("admins")
}

model Click {
  id        Int      @id @default(autoincrement())
  postId    Int
  url       String
  label     String?
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("clicks")
}

model PageView {
  id        Int      @id @default(autoincrement())
  postId    Int
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("page_views")
}

model CustomEditor {
  id              Int     @id @default(autoincrement())
  name            String
  icon            String
  html            String
  order           Int     @default(0)
  defaultInsert   Boolean @default(false)
  defaultPosition String  @default("bottom") // "top" | "bottom"

  @@map("custom_editors")
}

model Banner {
  id       Int    @id @default(autoincrement())
  label    String
  url      String
  imageUrl String?
  order    Int    @default(0)

  @@map("banners")
}

model Writer {
  id        Int     @id @default(autoincrement())
  name      String
  avatarUrl String?
  order     Int     @default(0)
  posts     Post[]

  @@map("writers")
}

model LineTemplate {
  id        Int      @id @default(autoincrement())
  name      String   @default("デフォルト")
  styles    String   // JSON形式でスタイル設定を保存
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("line_templates")
}

// サービス紹介バナー（/service ページに表示）
model Service {
  id        Int      @id @default(autoincrement())
  label     String   // 表示名（alt属性・ホバー時にも利用）
  url       String   // リンク先URL
  imageUrl  String?  // バナー画像URL
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("services")
}
